{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/_scripts/notify.sh 'Waiting for approval' 'Claude needs your permission to continue'"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "fish -c 'if test -f .worktreeinclude; for file in (git ls-files --others --ignored --exclude-from=.worktreeinclude); mkdir -p (dirname $CLAUDE_WORKTREE_PATH/$file); cp $file $CLAUDE_WORKTREE_PATH/$file; end; end'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/_scripts/notify-sound.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/_scripts/session-track.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/_scripts/session-track.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/marc/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "claude-mem@thedotmack": false,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754765047256
  }
}
